{
  "metadata": [
    {
      "src": [
        {
          "src": "../../engine/managed/BasilEngine",
          "files": [ "BasilEngine.csproj" ]
        }
      ],
      "dest": "api"
    }
  ],
  "build": {
    "content": [
      {
        "files": [
          "api/**.yml",
          "api/index.md"
        ]
      },
      {
        "files": [
          "articles/**.md",
          "toc.yml"
        ]
      }
    ],
    "resource": [
      {
        "files": [
          "articles/images/**"
        ]
      }
    ],
    "dest": "_site",
    "globalMetadata": {
      "_appTitle": "Basil Engine API",
      "_enableSearch": true
    },
    "template": [
      "default"
    ]
  }
}
